{
  "name": "pi-tidy",
  "private": true,
  "description": "Monorepo for independently published @mobrienv/pi-tidy-* packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikeyobrien/pi-tidy-tools.git"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-tidy-tools/index.ts"
    ]
  },
  "scripts": {
    "test": "npm test --workspaces --if-present && node scripts/test-pack.mjs",
    "check": "npm run check --workspaces --if-present",
    "test:pack": "node scripts/test-pack.mjs"
  }
}
