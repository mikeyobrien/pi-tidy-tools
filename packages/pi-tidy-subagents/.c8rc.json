{
  "exclude": [
    "**/test/**",
    "**/vendor/**",
    "**/docs/**",
    "**/*.test.ts",
    "**/node_modules/**"
  ],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "statements": 95,
  "branches": 75,
  "functions": 90,
  "lines": 95
}
