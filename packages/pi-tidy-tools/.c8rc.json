{
  "all": true,
  "src": [".test-dist"],
  "extension": [".js"],
  "exclude": [
    "**/test/**",
    "**/vendor/**",
    "**/docs/**",
    "**/scripts/**",
    "**/*.test.js",
    "**/node_modules/**"
  ],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "per-file": true,
  "statements": 90,
  "branches": 80,
  "functions": 90,
  "lines": 90
}
