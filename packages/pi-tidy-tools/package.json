{
  "name": "@mobrienv/pi-tidy-tools",
  "version": "0.2.0",
  "description": "Compact, reason-first tool output for pi with configurable layouts, live status, and diffs on demand.",
  "license": "MIT",
  "author": "Mikey O'Brien <m@mobrienv.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikeyobrien/pi-tidy-tools.git",
    "directory": "packages/pi-tidy-tools"
  },
  "homepage": "https://github.com/mikeyobrien/pi-tidy-tools/tree/main/packages/pi-tidy-tools#readme",
  "bugs": "https://github.com/mikeyobrien/pi-tidy-tools/issues",
  "engines": {
    "node": ">=22.19.0"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "developer-tools"
  ],
  "files": [
    "index.ts",
    "config.ts",
    "render.ts",
    "vendor/**/*.ts",
    "README.md",
    "LICENSE",
    "docs/*.png"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "pretest": "node ../../scripts/bundle-core.mjs .",
    "test": "node scripts/test.mjs",
    "check": "node ../../scripts/bundle-core.mjs . && tsc --noEmit",
    "prepack": "node ../../scripts/bundle-core.mjs ."
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.6 <0.81.0",
    "@earendil-works/pi-tui": ">=0.80.6 <0.81.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/node": "22.10.2",
    "typescript": "5.6.3"
  }
}
